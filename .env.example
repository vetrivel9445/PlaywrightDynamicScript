# Copy to `.env` and adjust. Every value is optional — leave blank to use the
# default org connected to VS Code and the built-in defaults.

# Override the org to target (username or alias). Empty = default org in VS Code.
SF_TARGET_ORG=

# Dynamic landing page after login (relative path or full URL).
SF_START_PATH=/lightning/page/home

# Comma-separated file paths for the dynamic UI upload helper.
SF_UPLOAD_FILES=./data/sample.pdf

# Where the cached authenticated session is written.
SF_STORAGE_STATE=.auth/org-session.json

# Optional fallback instance URL if the Salesforce CLI is unavailable at
# config-load time (e.g. typecheck-only CI).
SF_INSTANCE_URL=
